# Local development template
# Keep the PythonAnywhere MySQL values blank to use SQLite files locally.

# Django core
DJANGO_SECRET_KEY=replace-with-a-local-dev-secret
DJANGO_DEBUG=True

# Blank values force the SQLite fallback in repairshop/settings.py.
PA_DB_HOST=
PA_DB_PORT=3306
PA_DB_USER=
PA_DB_PASSWORD=
PA_DEFAULT_DB_NAME=
PA_SHOP1_DB_NAME=
PA_SHOP2_DB_NAME=
TENANT_DB_ALIASES=

# MotorAPI token used by /api/vehicle/<plate>/ lookup endpoint
MOTORAPI_AUTH_TOKEN=
MOTORAPI_BASE_URL=https://v1.motorapi.dk
MOTORAPI_VERIFY_SSL=True

# Local email testing:
# - use django.core.mail.backends.smtp.EmailBackend to send real emails
# - use django.core.mail.backends.filebased.EmailBackend to write emails to tmp/sent_emails
# - use django.core.mail.backends.console.EmailBackend to print emails to the terminal
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=invoice@repairshop.local
