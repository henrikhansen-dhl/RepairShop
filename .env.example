# Django core
DJANGO_SECRET_KEY=replace-with-a-secure-secret-key
DJANGO_DEBUG=False

# PythonAnywhere MySQL connection (shared credentials)
# Example host: yourusername.mysql.pythonanywhere-services.com
PA_DB_HOST=yourusername.mysql.pythonanywhere-services.com
PA_DB_PORT=3306
PA_DB_USER=yourusername
PA_DB_PASSWORD=your-db-password

# Shared/default database (stores auth + ShopProfile metadata)
# Example name format on PythonAnywhere: yourusername$repairshop_default
PA_DEFAULT_DB_NAME=yourusername$repairshop_default

# Pre-registered tenant aliases from settings.py
# shop1_db -> PA_SHOP1_DB_NAME
# shop2_db -> PA_SHOP2_DB_NAME
PA_SHOP1_DB_NAME=yourusername$shop1_db
PA_SHOP2_DB_NAME=yourusername$shop2_db

# Optional dynamic aliases (comma-separated)
# If alias is "shop3_db", settings expects PA_SHOP3_DB_NAME
TENANT_DB_ALIASES=shop3_db,shop4_db
PA_SHOP3_DB_NAME=yourusername$shop3_db
PA_SHOP4_DB_NAME=yourusername$shop4_db

# MotorAPI token used by /api/vehicle/<plate>/ lookup endpoint
# Keep this secret and set your real token in local .env
MOTORAPI_AUTH_TOKEN=replace-with-your-motorapi-token
MOTORAPI_BASE_URL=https://v1.motorapi.dk

# Keep SSL verification enabled in normal cases.
# Set False only for local environments with TLS/certificate interception issues.
MOTORAPI_VERIFY_SSL=True

# Outgoing email settings (used for invoice email feature)
# For local development you can keep console backend to print emails in terminal.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.yourprovider.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-smtp-user
EMAIL_HOST_PASSWORD=your-smtp-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=invoice@yourshop.com
