# Production environment template
# Copy values from here into your real production environment (do not commit secrets).

# Django core
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False

# PythonAnywhere / MySQL shared connection settings
PA_DB_HOST=yourusername.mysql.pythonanywhere-services.com
PA_DB_PORT=3306
PA_DB_USER=yourusername
PA_DB_PASSWORD=replace-with-strong-db-password

# Shared/default DB (auth + shop metadata)
PA_DEFAULT_DB_NAME=yourusername$repairshop_default

# Pre-registered tenant DBs used in settings.py
PA_SHOP1_DB_NAME=yourusername$shop1_db
PA_SHOP2_DB_NAME=yourusername$shop2_db

# Optional dynamic aliases
# Comma-separated aliases. For each alias, set PA_<ALIAS_UPPER>_NAME.
TENANT_DB_ALIASES=shop3_db,shop4_db
PA_SHOP3_DB_NAME=yourusername$shop3_db
PA_SHOP4_DB_NAME=yourusername$shop4_db

# MotorAPI token for server-side vehicle lookup endpoint
MOTORAPI_AUTH_TOKEN=61nl9h280epc5i77sbk9wvmu7zy5xlk7
MOTORAPI_BASE_URL=https://v1.motorapi.dk

# Always keep SSL verification enabled in production.
MOTORAPI_VERIFY_SSL=True
